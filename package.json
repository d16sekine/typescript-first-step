    "check:exercises": "tsc -p exercises",
    "check:all": "yarn type-check && yarn check:tests && yarn check:exercises",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d16sekine/typescript-first-step.git"
