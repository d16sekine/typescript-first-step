{
  "name": "typescript-first-step",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx src/01-first-step.ts",
    "build": "tsc",
    "start": "node dist/01-first-step.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
